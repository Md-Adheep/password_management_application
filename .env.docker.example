# ═══════════════════════════════════════════════════════════════════════════════
# .env.docker.example — Docker / docker-compose environment variables
#
# Usage:
#   cp .env.docker.example .env
#   # Edit .env with your real values, then:
#   docker compose up --build
#
# NEVER commit the actual .env to git.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Flask secrets ─────────────────────────────────────────────────────────────
# Generate strong random values:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-secret-key
JWT_SECRET_KEY=change-this-to-a-random-jwt-key

# ── Fernet encryption key ─────────────────────────────────────────────────────
# Generate once and keep forever (changing it makes all stored passwords unreadable):
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-key-here

# ── Database ──────────────────────────────────────────────────────────────────
# These are used by BOTH the app service AND the MySQL service in docker-compose.
DB_NAME=password_manager
DB_USER=corpvault
DB_PASSWORD=change-this-db-password
MYSQL_ROOT_PASSWORD=change-this-root-password

# ── Port overrides (optional) ─────────────────────────────────────────────────
APP_PORT=5000          # Host port mapped to the Flask container
DB_EXPOSE_PORT=3306    # Host port for direct MySQL access (TablePlus, etc.)

# ── Gunicorn ─────────────────────────────────────────────────────────────────
GUNICORN_WORKERS=2
LOG_LEVEL=info
